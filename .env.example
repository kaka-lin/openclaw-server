# ==========================================
# OpenClaw Server Configuration
# ==========================================

# 資料目錄 (host 端路徑)
OPENCLAW_CONFIG_DIR=${HOME}/.openclaw
OPENCLAW_WORKSPACE_DIR=${HOME}/.openclaw/workspace

# Gateway Auth Token
# 留空時 setup.sh 會自動產生並回寫至此檔與 ~/.openclaw/openclaw.json
OPENCLAW_GATEWAY_TOKEN=

# Gateway 連線設定
OPENCLAW_GATEWAY_HOST=localhost
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan

# 時區 (Docker container 內的 Node.js 使用)
TZ=Asia/Taipei

# =========================================================
# Control UI CORS 白名單（重要 ⚠️）
# =========================================================
# 1) 留空：只允許 localhost / 127.0.0.1
# 2) 填 IP 或 domain：會額外加入白名單
# 3) 設 "*"：完全開放，不建議公開環境使用
OPENCLAW_ALLOWED_ORIGINS=

# =========================================================
# 允許非 HTTPS 的 WebSocket 連線
# =========================================================
# 區網 (LAN) 使用 Control UI 必須開啟
# 若使用 HTTPS 反向代理（nginx / cloudflare）建議關閉
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1

# ==========================================
# Stability & Self-Healing (穩定性與自動修復)
# ==========================================

# Telegram 輪詢卡死偵測超時 (毫秒)，預設 60000 (1分鐘)
TELEGRAM_POLLING_STALL_TIMEOUT=60000

# ==========================================
# AI Model Provider API Keys
# ==========================================

# Anthropic (Claude)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (GPT)
# https://platform.openai.com/
OPENAI_API_KEY=

# Google (Gemini)
# https://aistudio.google.com/
GEMINI_API_KEY=

# ==========================================
# Messaging Platforms / Channels
# ==========================================

# Telegram Bot Token 
# (配置好 channel 後 OpenClaw 會記在內部資料庫，這裡可用於備忘或之後給 Growth Engine 使用)
TELEGRAM_BOT_TOKEN=

# Discord Bot Token (main agent)
DISCORD_BOT_TOKEN=

# Discord 身分與伺服器 ID（所有 Agent 共用）
DISCORD_USER_ID=
DISCORD_SERVER_ID=

# Discord Multi-Agent Bot Tokens（選用）
# 若需要多個 Agent 各自擁有獨立的 Discord Bot，請依以下格式新增。
# 變數命名規則：DISCORD_BOT_TOKEN_<AGENT_NAME_大寫>
# 詳細說明：docs/guides/multi-agent-discord.md
#
# DISCORD_BOT_TOKEN_CODER=
# DISCORD_BOT_TOKEN_RESEARCHER=
# DISCORD_BOT_TOKEN_WRITER=
# DISCORD_BOT_TOKEN_SENTINEL=
