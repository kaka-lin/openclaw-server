# ==========================================
# OpenClaw Server Configuration
# ==========================================

# Docker Image (官方 pre-built image)
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# 資料目錄 (host 端路徑)
OPENCLAW_CONFIG_DIR=~/.openclaw
OPENCLAW_WORKSPACE_DIR=~/.openclaw/workspace

# Gateway Auth Token
# 留空時 setup.sh 會自動產生並回寫至此檔與 ~/.openclaw/openclaw.json
OPENCLAW_GATEWAY_TOKEN=

# Gateway 連線設定
OPENCLAW_GATEWAY_HOST=localhost
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan

# =========================================================
# Control UI CORS 白名單（重要 ⚠️）
# =========================================================
# 1) 留空：只允許 localhost / 127.0.0.1
# 2) 填 IP 或 domain：會額外加入白名單
# 3) 設 "*"：完全開放，不建議公開環境使用
OPENCLAW_ALLOWED_ORIGINS=

# =========================================================
# 允許非 HTTPS 的 WebSocket 連線
# =========================================================
# 區網 (LAN) 使用 Control UI 必須開啟
# 若使用 HTTPS 反向代理（nginx / cloudflare）建議關閉
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1

# 時區 (Docker container 內的 Node.js 使用)
TZ=Asia/Taipei

# =========================================================
# Sandbox / Docker Socket 設定
# =========================================================
# 0 = 關閉（預設）
# 1 = 啟用
#
# 注意：
# 1. 這個值本身不會自動讓 docker-compose 掛上 docker.sock
# 2. 啟用時，請另外疊加 docker-compose.sandbox.yml
# 3. 啟用後，還需要用 openclaw-cli 寫入 sandbox 設定
OPENCLAW_SANDBOX=0

# Host Docker socket 路徑
# 只有在啟用 sandbox 並使用 docker-compose.sandbox.yml 時才需要
OPENCLAW_DOCKER_SOCKET=/var/run/docker.sock

# docker.sock 在 host 上的 group id
# 只有在啟用 sandbox 時才需要正確設定
DOCKER_GID=0

# ==========================================
# AI Model Provider API Keys
# ==========================================

# Anthropic (Claude)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (GPT)
# https://platform.openai.com/
OPENAI_API_KEY=

# Google (Gemini)
# https://aistudio.google.com/
GEMINI_API_KEY=

# ==========================================
# Messaging Platforms / Channels
# ==========================================

# Telegram Bot Token 
# (配置好 channel 後 OpenClaw 會記在內部資料庫，這裡可用於備忘或之後給 Growth Engine 使用)
TELEGRAM_BOT_TOKEN=
