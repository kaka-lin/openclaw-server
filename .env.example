# ==========================================
# OpenClaw Server Configuration
# ==========================================

# Docker Image (官方 pre-built image)
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# 資料目錄 (host 端路徑)
OPENCLAW_CONFIG_DIR=~/.openclaw
OPENCLAW_WORKSPACE_DIR=~/.openclaw/workspace

# Gateway Auth Token
# 留空時 setup.sh 會自動產生並回寫至此檔與 ~/.openclaw/openclaw.json
OPENCLAW_GATEWAY_TOKEN=

# Gateway 連線設定
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_BIND=lan

# 時區 (Docker container 內的 Node.js 使用)
TZ=Asia/Taipei

# Sandbox 沙盒功能 (1=啟用)
OPENCLAW_SANDBOX=1

# ==========================================
# AI Model Provider API Keys
# ==========================================

# Anthropic (Claude)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (GPT)
# https://platform.openai.com/
OPENAI_API_KEY=

# Google (Gemini)
# https://aistudio.google.com/
GEMINI_API_KEY=
