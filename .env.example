# ==========================================
# OpenClaw Server Configuration
# ==========================================

# Docker Image (官方 pre-built image)
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# 資料目錄 (host 端路徑)
OPENCLAW_CONFIG_DIR=~/.openclaw
OPENCLAW_WORKSPACE_DIR=~/.openclaw/workspace

# Gateway Auth Token
# 留空時 setup.sh 會自動產生並回寫至此檔與 ~/.openclaw/openclaw.json
OPENCLAW_GATEWAY_TOKEN=

# Gateway 連線設定
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan

# =========================================================
# Control UI CORS 白名單（重要 ⚠️）
# =========================================================
# 行為規則（由 setup.sh 控制）：
#
# 1️⃣ 留空 → 僅允許 localhost
#    => http://localhost:PORT
#       http://127.0.0.1:PORT
#
# 2️⃣ 設定 IP / domain → 自動 append（會保留 localhost）
#
#    ✅ 正確範例：
#      OPENCLAW_ALLOWED_ORIGINS=192.168.1.100
#      OPENCLAW_ALLOWED_ORIGINS=http://mac-mini.local:18789
#
#      OPENCLAW_ALLOWED_ORIGINS=192.168.1.100,192.168.1.101
#      OPENCLAW_ALLOWED_ORIGINS='["http://192.168.1.100:18789","http://192.168.1.101:18789"]'
#
#    ❌ 錯誤範例（會被錯誤解析）：
#      OPENCLAW_ALLOWED_ORIGINS=192.168.1.100, 192,168.1.101
#      ↑ 逗號會被當作分隔符，IP 會被切壞
#
# 3️⃣ 設定 "*" → 完全開放（⚠️ 會覆蓋所有設定）
#    => ["*"]
#    ⚠️ 注意：不能與其他 domain 混用（CORS 規則限制）
OPENCLAW_ALLOWED_ORIGINS=

# =========================================================
# 允許非 HTTPS 的 WebSocket 連線
# =========================================================
# 區網 (LAN) 使用 Control UI 必須開啟
# 若使用 HTTPS 反向代理（nginx / cloudflare）建議關閉
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1

# 時區 (Docker container 內的 Node.js 使用)
TZ=Asia/Taipei

# Sandbox 沙盒功能 (預設關閉：0)
# 若在 Docker 內執行需額外配置 Docker CLI 權限，目前用於純對話/Growth Engine 建議保持關閉
OPENCLAW_SANDBOX=0

# ==========================================
# AI Model Provider API Keys
# ==========================================

# Anthropic (Claude)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (GPT)
# https://platform.openai.com/
OPENAI_API_KEY=

# Google (Gemini)
# https://aistudio.google.com/
GEMINI_API_KEY=

# ==========================================
# Messaging Platforms / Channels
# ==========================================

# Telegram Bot Token 
# (配置好 channel 後 OpenClaw 會記在內部資料庫，這裡可用於備忘或之後給 Growth Engine 使用)
TELEGRAM_BOT_TOKEN=
